{
  "entities": {
    "Key": {
      "title": "Key",
      "description": "A key that can be generated by users.",
      "type": "object",
      "properties": {
        "key": {
          "type": "string",
          "description": "The actual key string."
        },
        "lastUsedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The last time this key was generated."
        }
      },
      "required": ["key"]
    },
    "User": {
      "title": "User",
      "description": "User profile with cooldown information.",
      "type": "object",
      "properties": {
        "lastGeneratedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The last time this user generated a key."
        }
      }
    }
  },
  "firestore": {
    "/keys/{keyId}": {
      "schema": "Key",
      "description": "Collection of available keys."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user cooldowns."
    }
  }
}
